#include &lt;iostream&gt;
using namespace std;

void areaCirculo(double radio) {
double area = 3.1416 * radio * radio;
cout &lt;&lt; &quot;Area del circulo: &quot; &lt;&lt; area &lt;&lt; endl;
}

void factorial(int n) {
long long fact = 1;
for (int i = 1; i &lt;= n; i++) {
fact *= i;
}
cout &lt;&lt; &quot;Factorial: &quot; &lt;&lt; fact &lt;&lt; endl;
}

void parImpar(int n) {
if (n % 2 == 0)
cout &lt;&lt; &quot;El numero es PAR\n&quot;;
else

cout &lt;&lt; &quot;El numero es IMPAR\n&quot;;
}

